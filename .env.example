# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Webhook authentication — generate with: openssl rand -hex 24
SECRET_TOKEN=

# Telegram notifications (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Freqtrade API password (must match config.json jwt_secret_key area / api_server.password)
FREQTRADE_PASS=

# Default trading pair
TRADING_PAIR=SOL/USD

# Position sizing
STAKE_RATIO=0.5      # fraction of free balance per buy (0.5 = 50%)
SELL_RATIO=0.5       # fraction of position per sell (0.5 = 50%)
MIN_STAKE=10         # minimum USD stake, skips buy if below this

# Self-hosted only (docker-compose.selfhosted.yml)
# Option A: name of your existing Cloudflare Tunnel Docker network
DOCKER_NETWORK=

# Option B: Cloudflare Tunnel token (if using bundled cloudflared)
CLOUDFLARE_TUNNEL_TOKEN=
