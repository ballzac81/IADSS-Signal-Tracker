# ── IADSS Configuration ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values, OR run ./setup.sh
# NEVER commit .env to version control — it contains secrets.

# ── Setup path ────────────────────────────────────────────────────────────────
# vps        = Cloud VPS with Caddy (auto HTTPS, ports 80+443 must be open)
# selfhosted = Home server/Unraid/NAS with Cloudflare Tunnel (no open ports)
SETUP_PATH=vps

# ── Domains ───────────────────────────────────────────────────────────────────
# Both must resolve to your server (VPS IP via A records, or Cloudflare Tunnel).
SIGNAL_DOMAIN=signals.yourdomain.com
FREQTRADE_DOMAIN=trade.yourdomain.com

# ── Cloudflare Tunnel (self-hosted path only) ─────────────────────────────────
# Get this from Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
# Leave blank if using the VPS path.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 24
SECRET_TOKEN=

# Generate: openssl rand -hex 16
FREQTRADE_PASS=

# Generate: openssl rand -hex 32
FREQTRADE_JWT_SECRET=

# ── Exchange ──────────────────────────────────────────────────────────────────
EXCHANGE_NAME=kraken
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Signal Window ─────────────────────────────────────────────────────────────
# 4h chart × 10 candles = 144000 | 1h chart × 10 candles = 36000
WI