{
    "max_open_trades": 10,
    "stake_currency": "USDC",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.5,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",

    "exchange": {
        "name": "hyperliquid",
        "walletAddress": "CHANGE_THIS_your_main_wallet_address",
        "privateKey": "CHANGE_THIS_your_api_wallet_private_key",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "SOL/USDC:USDC"
        ],
        "pair_blacklist": []
    },

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },

    "exit_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1
    },

    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "stoploss": "limit",
        "stoploss_on_exchange": true,
        "stoploss_on_exchange_interval": 60
    },

    "order_time_in_force": {
        "entry": "GTC",
        "exit": "GTC"
    },

    "telegram": {
        "enabled": true,
        "token": "CHANGE_THIS_telegram_bot_token",
        "chat_id": "CHANGE_THIS_telegram_chat_id"
    },

    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "CHANGE_THIS_random_32_char_string",
        "CORS_origins": [],
        "username": "admin",
        "password": "CHANGE_THIS_freqtrade_api_password"
    },

    "bot_name": "IADSS-Hyperliquid",

    "force_entry_enable": true,

    "internals": {
        "process_throttle_secs": 5
    }
}
